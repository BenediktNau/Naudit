{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Naudit": {
    "Ai": {
      "Provider": "Ollama",
      "Model": "llama3.1",
      "Endpoint": "http://localhost:11434",
      "ApiKey": ""
    },
    "Git": {
      "Platform": "GitLab"
    },
    "GitLab": {
      "BaseUrl": "https://gitlab.example.com",
      "Token": "",
      "WebhookSecret": "",
      "PostVerdict": false
    },
    "GitHub": {
      "BaseUrl": "https://api.github.com",
      "Token": "",
      "WebhookSecret": "",
      "Auth": "Pat",
      "PostVerdict": false,
      "App": {
        "AppId": "",
        "PrivateKey": "",
        "InstallationId": null
      }
    },
    "Review": {
      "SystemPrompt": "",
      "Gate": {
        "MinSeverity": "High",
        "MinConfidence": "Medium"
      }
    },
    "Sast": {
      "Enabled": false,
      "Analyzers": [ "opengrep", "trivy" ],
      "Reducer": "deterministic",
      "AnalyzerTimeout": "00:05:00",
      "MaxFindingsPerGroup": 20
    },
    "Redaction": {
      "Enabled": true,
      "EntropyThreshold": 4.0,
      "MinEntropyTokenLength": 20
    }
  }
}
