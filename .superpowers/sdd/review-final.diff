+            ["Naudit:Ai:Provider"] = "ClaudeCode",
+            ["Naudit:Review:Mcp:Enabled"] = "true",
+            ["Naudit:Review:Mcp:Servers:0:Name"] = "context7",
+            ["Naudit:Review:Mcp:Servers:0:Url"] = "https://mcp.context7.com/mcp",
+        });
